# Sentinel AI API - Local Configuration Settings Template
PROJECT_NAME="Sentinel AI Playbook Platform"
API_V1_STR="/api/v1"
SECRET_KEY="super-secret-key-change-in-production-wealth-sentinel-ai-2026"
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Resilient Database URL
# Left blank or set to unreachable postgres automatically fallbacks 
# cleanly to a local SQLite 'sentinel.db' in the apps folder.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sentinel"

# Redis Cache Url
REDIS_URL="redis://localhost:6379/0"

# Optional OpenAI API Key
# If left empty, the platform dynamically activates its intelligent 
# multi-agent mock system, rendering premium mock playbooks and traces offline.
OPENAI_API_KEY=""
